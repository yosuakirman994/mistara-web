<%- include('layout/header') %>
<main class="page-container" style="padding: 6rem 5%; max-width: 1200px; margin: 0 auto; min-height: 70vh;">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem; flex-wrap: wrap; gap: 1rem;">
        <h1 class="section-title" style="margin-bottom: 0;">Kelola Anggota</h1>
        <button onclick="document.getElementById('addUserModal').style.display='flex'" class="btn-primary" style="padding: 0.8rem 1.5rem; font-size: 0.9rem;">
            <i class="fa-solid fa-plus"></i> Tambah User Baru
        </button>
    </div>
    
    <% if(locals.error) { %>
        <div style="background: #fee2e2; border-left: 4px solid #dc2626; color: #b91c1c; padding: 1rem; margin-bottom: 2rem; border-radius: 0 8px 8px 0;">
            <i class="fa-solid fa-circle-exclamation"></i> <%= error %>
        </div>
    <% } %>

    <div class="glass-card" style="padding: 2rem; overflow-x: auto;">
        <table style="width: 100%; border-collapse: collapse; text-align: left; min-width: 600px;">
            <thead>
                <tr style="border-bottom: 2px solid var(--primary); color: var(--primary);">
                    <th style="padding: 1rem;">Nama</th>
                    <th style="padding: 1rem;">Email</th>
                    <th style="padding: 1rem;">Role</th>
                    <th style="padding: 1rem; text-align: right;">Aksi</th>
                </tr>
            </thead>
            <tbody>
                <% userList.forEach(u => { %>
                <tr style="border-bottom: 1px solid var(--border);">
                    <td style="padding: 1rem; font-weight: 600; color: var(--text-dark);"><%= u.name %></td>
                    <td style="padding: 1rem; color: var(--text-muted);"><%= u.email %></td>
                    <td style="padding: 1rem;">
                        <span style="padding: 0.3rem 0.8rem; border-radius: 20px; font-size: 0.8rem; font-weight: bold; background: <%= u.role === 'Admin' ? '#fee2e2' : '#dcfce7' %>; color: <%= u.role === 'Admin' ? '#991b1b' : '#166534' %>;">
                            <%= u.role %>
                        </span>
                    </td>
                    <td style="padding: 1rem; text-align: right; display: flex; gap: 0.5rem; justify-content: flex-end;">
                        <% if(u.id !== user.id) { %>
                        <form action="/users/delete/<%= u.id %>" method="POST" onsubmit="return confirm('Peringatan: Hapus akses login secara permanen untuk <%= u.name %>?');">
                            <button type="submit" style="background: #dc2626; color: white; border: none; padding: 6px 12px; border-radius: 6px; cursor: pointer; font-size: 0.85rem; transition: opacity 0.2s;" onmouseover="this.style.opacity='0.8'" onmouseout="this.style.opacity='1'"><i class="fa-solid fa-trash"></i> Hapus Akses</button>
                        </form>
                        <% } else { %>
                            <span style="color: var(--text-muted); font-size: 0.8rem; font-style: italic;">(Anda)</span>
                        <% } %>
                    </td>
                </tr>
                <% }) %>
            </tbody>
        </table>
    </div>

    <!-- Modal Tambah User -->
    <div id="addUserModal" style="display: <%= locals.error ? 'flex' : 'none' %>; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5); z-index: 1000; justify-content: center; align-items: center;">
        <div class="glass-card" style="background: white; padding: 2rem; border-radius: 12px; width: 90%; max-width: 400px; box-shadow: 0 10px 25px rgba(0,0,0,0.2);">
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem;">
                <h3 style="color: var(--primary); margin: 0;">Tambah Akses Login</h3>
                <button onclick="document.getElementById('addUserModal').style.display='none'" style="background: none; border: none; font-size: 1.2rem; cursor: pointer; color: var(--text-muted);">&times;</button>
            </div>
            
            <form action="/users/add" method="POST" style="display: flex; flex-direction: column; gap: 1rem;">
                <div>
                    <label style="display: block; font-size: 0.9rem; font-weight: 600; margin-bottom: 0.5rem; color: var(--text-dark);">Nama Lengkap</label>
                    <input type="text" name="name" required placeholder="Nama Pengurus Baru" style="width: 100%; padding: 0.8rem; border: 1px solid var(--border); border-radius: 8px;">
                </div>
                <div>
                    <label style="display: block; font-size: 0.9rem; font-weight: 600; margin-bottom: 0.5rem; color: var(--text-dark);">Email</label>
                    <input type="email" name="email" required placeholder="pengurus@email.com" style="width: 100%; padding: 0.8rem; border: 1px solid var(--border); border-radius: 8px;">
                </div>
                <div>
                    <label style="display: block; font-size: 0.9rem; font-weight: 600; margin-bottom: 0.5rem; color: var(--text-dark);">Kata Sandi Sementara</label>
                    <input type="password" name="password" required placeholder="Minimal 6 karakter" style="width: 100%; padding: 0.8rem; border: 1px solid var(--border); border-radius: 8px;">
                </div>
                <div>
                    <label style="display: block; font-size: 0.9rem; font-weight: 600; margin-bottom: 0.5rem; color: var(--text-dark);">Peran (Role)</label>
                    <select name="role" required style="width: 100%; padding: 0.8rem; border: 1px solid var(--border); border-radius: 8px; background: white;">
                        <option value="Pengurus">Pengurus (Bisa Tambah/Edit Jadwal)</option>
                        <option value="Admin">Admin (Punya Akses ke Halaman Ini)</option>
                    </select>
                </div>
                <button type="submit" class="btn-primary" style="margin-top: 0.5rem;">Simpan & Berikan Akses</button>
            </form>
        </div>
    </div>
</main>
<%- include('layout/footer') %>
