<%- include('layout/header') %>
<main class="page-container" style="padding: 6rem 5%; max-width: 1200px; margin: 0 auto; min-height: 70vh;">
    <h1 class="section-title">Dashboard Pengurus</h1>
    
    <div style="display: grid; grid-template-columns: 250px 1fr; gap: 2rem; align-items: start;">
        <aside class="glass-card" style="padding: 2rem 1.5rem;">
            <div style="text-align: center; margin-bottom: 2rem;">
                <div style="width: 80px; height: 80px; background-color: var(--accent); color: white; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 2rem; margin: 0 auto 1rem;">
                    <i class="fa-solid fa-user-shield"></i>
                </div>
                <h3 style="color: var(--primary);"><%= user.name %></h3>
                <span style="display: inline-block; padding: 0.2rem 0.8rem; background: var(--bg-light); color: var(--accent); border-radius: 20px; font-size: 0.8rem; font-weight: 600; margin-top: 0.5rem;"><%= user.role %></span>
            </div>
            
            <ul style="display: flex; flex-direction: column; gap: 0.5rem;">
                <li><a href="/dashboard" style="display: block; padding: 0.8rem 1rem; background-color: rgba(139, 90, 43, 0.1); color: var(--accent); border-radius: 8px; font-weight: 600;"><i class="fa-solid fa-house" style="width: 20px;"></i> Beranda</a></li>
                <li><a href="/schedule" style="display: block; padding: 0.8rem 1rem; color: var(--text-muted); border-radius: 8px;"><i class="fa-solid fa-calendar" style="width: 20px;"></i> Kelola Jadwal</a></li>
                <li><a href="#" onclick="alert('Fitur Kelola Anggota akan ditambahkan pada tahap selanjutnya!'); return false;" style="display: block; padding: 0.8rem 1rem; color: var(--text-muted); border-radius: 8px;"><i class="fa-solid fa-users" style="width: 20px;"></i> Kelola Anggota</a></li>
                <li style="margin-top: 1rem;"><a href="/logout" style="display: block; padding: 0.8rem 1rem; color: #DC2626; border-radius: 8px;"><i class="fa-solid fa-arrow-right-from-bracket" style="width: 20px;"></i> Keluar</a></li>
            </ul>
        </aside>
        
        <section class="glass-card">
            <h2 style="color: var(--primary); margin-bottom: 1.5rem;">Selamat Datang, <%= user.name %>!</h2>
            <p style="color: var(--text-muted); margin-bottom: 2rem;">Anda masuk sebagai <strong><%= user.role %></strong>. Di sini Anda dapat mengelola berbagai aspek dari situs Mistara.</p>
            
            <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1.5rem;">
                <div style="border: 1px solid var(--border); padding: 1.5rem; border-radius: 12px; text-align: center; background: rgba(255,255,255,0.4);">
                    <i class="fa-solid fa-calendar-check" style="font-size: 2rem; color: var(--accent); margin-bottom: 1rem;"></i>
                    <h4 style="font-size: 1.2rem; color: var(--primary);">Jadwal</h4>
                    <p style="color: var(--text-muted); font-size: 0.9rem;"><%= locals.scheduleCount || 0 %> Acara Mendatang</p>
                </div>
                <div style="border: 1px solid var(--border); padding: 1.5rem; border-radius: 12px; text-align: center; background: rgba(255,255,255,0.4);">
                    <i class="fa-solid fa-bullhorn" style="font-size: 2rem; color: var(--accent); margin-bottom: 1rem;"></i>
                    <h4 style="font-size: 1.2rem; color: var(--primary);">Pengumuman</h4>
                    <p style="color: var(--text-muted); font-size: 0.9rem;">0 Berita Baru</p>
                </div>
            </div>
            
            <div style="margin-top: 3rem;">
                <h3 style="color: var(--primary); margin-bottom: 1rem; font-size: 1.2rem;">Aktivitas Terkini</h3>
                <p style="font-style: italic; color: #9ca3af;">Belum ada log aktivitas.</p>
            </div>
        </section>
    </div>
</main>
<%- include('layout/footer') %>
