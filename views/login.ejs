<%- include('layout/header') %>
<main class="page-container" style="padding: 10rem 5%; max-width: 500px; margin: 0 auto; min-height: 70vh;">
    <div class="glass-card">
        <h2 style="text-align: center; color: var(--primary); margin-bottom: 2rem;">Masuk (Login)</h2>
        
        <% if (locals.error) { %>
            <div style="background-color: #FEE2E2; color: #DC2626; padding: 1rem; border-radius: 8px; margin-bottom: 1.5rem; text-align: center;">
                <%= error %>
            </div>
        <% } %>

        <form action="/login" method="POST" style="display: flex; flex-direction: column; gap: 1.25rem;">
            <div>
                <label for="email" style="display: block; margin-bottom: 0.5rem; color: var(--text-dark); font-weight: 600;">Email</label>
                <input type="email" id="email" name="email" required placeholder="admin@mistara.id" style="width: 100%; padding: 0.8rem 1rem; border: 1px solid var(--border); border-radius: 8px; background: rgba(255,255,255,0.7); font-family: 'Outfit';">
            </div>
            <div>
                <label for="password" style="display: block; margin-bottom: 0.5rem; color: var(--text-dark); font-weight: 600;">Password</label>
                <input type="password" id="password" name="password" required placeholder="••••••••" style="width: 100%; padding: 0.8rem 1rem; border: 1px solid var(--border); border-radius: 8px; background: rgba(255,255,255,0.7); font-family: 'Outfit';">
            </div>
            <button type="submit" class="btn-primary" style="margin-top: 1rem; width: 100%;">Masuk</button>
        </form>
        
        <p style="text-align: center; margin-top: 2rem; color: var(--text-muted); font-size: 0.9rem;">
            Akses anggota biasa tidak memerlukan login.
        </p>
    </div>
</main>
<%- include('layout/footer') %>
