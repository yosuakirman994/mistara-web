<%- include('layout/header') %>
<main class="page-container" style="padding: 6rem 5%; max-width: 1200px; margin: 0 auto; min-height: 70vh;">
    <div class="calendar-wrapper glass-card" style="padding: 2.5rem; display: flex; flex-wrap: wrap; gap: 3rem; background: var(--card-bg);">
        
        <!-- Left Calendar -->
        <div class="calendar-left" style="flex: 2; min-width: 300px;">
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem; padding: 0 1rem;">
                <button id="prevMonth" style="background: var(--bg-light); border: 1px solid var(--border); border-radius: 50%; width: 40px; height: 40px; font-size: 1.2rem; cursor: pointer; color: var(--primary); transition: all 0.2s; display: flex; align-items: center; justify-content: center;"><i class="fa-solid fa-chevron-left"></i></button>
                <h2 id="currentMonthYear" style="font-size: 1.5rem; color: var(--text-dark); font-weight: 800; margin: 0;">Maret 2026</h2>
                <button id="nextMonth" style="background: var(--bg-light); border: 1px solid var(--border); border-radius: 50%; width: 40px; height: 40px; font-size: 1.2rem; cursor: pointer; color: var(--primary); transition: all 0.2s; display: flex; align-items: center; justify-content: center;"><i class="fa-solid fa-chevron-right"></i></button>
            </div>

            <div class="calendar-grid" id="calendarGrid">
                <!-- Days of week -->
                <div class="weekday">Sen</div>
                <div class="weekday">Sel</div>
                <div class="weekday">Rab</div>
                <div class="weekday">Kam</div>
                <div class="weekday">Jum</div>
                <div class="weekday">Sab</div>
                <div class="weekday">Min</div>
                
                <!-- Days will be generated by JS -->
            </div>
        </div>

        <!-- Right Sidebar (Events) -->
        <div class="calendar-right" style="flex: 1; min-width: 300px;">
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem;">
                <h3 id="eventListTitle" style="font-size: 1.2rem; color: var(--text-dark);">Kegiatan Bulan Ini</h3>
            </div>

            <div id="eventList" style="display: flex; flex-direction: column; gap: 1rem; max-height: 400px; overflow-y: auto; padding-right: 10px;">
                <!-- Events generated by JS -->
            </div>
            
            <% if(locals.user && (user.role === 'Admin' || user.role === 'Pengurus')) { %>
            <div style="margin-top: 2rem; text-align: right;">
                <button onclick="document.getElementById('addEventModal').style.display='flex'" style="width: 50px; height: 50px; border-radius: 50%; background: #6366f1; color: white; border: none; font-size: 1.5rem; cursor: pointer; display: inline-flex; align-items: center; justify-content: center; box-shadow: 0 4px 10px rgba(99, 102, 241, 0.4); transition: transform 0.2s;" onmouseover="this.style.transform='scale(1.1)'" onmouseout="this.style.transform='scale(1)'">
                    <i class="fa-solid fa-plus"></i>
                </button>
            </div>
            
            <!-- Modal Pop-up Tambah Jadwal -->
            <div id="addEventModal" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5); z-index: 1000; justify-content: center; align-items: center;">
                <div class="glass-card" style="background: white; padding: 2rem; border-radius: 12px; width: 90%; max-width: 400px; box-shadow: 0 10px 25px rgba(0,0,0,0.2);">
                    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem;">
                        <h3 style="color: var(--primary); margin: 0;">Tambah Kegiatan</h3>
                        <button onclick="document.getElementById('addEventModal').style.display='none'" style="background: none; border: none; font-size: 1.2rem; cursor: pointer; color: var(--text-muted);">&times;</button>
                    </div>
                    <form action="/schedule/add" method="POST" style="display: flex; flex-direction: column; gap: 1rem;">
                        <div>
                            <label style="display: block; font-size: 0.9rem; font-weight: 600; margin-bottom: 0.5rem; color: var(--text-dark);">Nama Kegiatan</label>
                            <input type="text" name="title" required placeholder="Latihan Koor" style="width: 100%; padding: 0.8rem; border: 1px solid var(--border); border-radius: 8px;">
                        </div>
                        <div>
                            <label style="display: block; font-size: 0.9rem; font-weight: 600; margin-bottom: 0.5rem; color: var(--text-dark);">Tanggal</label>
                            <input type="date" name="date" required style="width: 100%; padding: 0.8rem; border: 1px solid var(--border); border-radius: 8px;">
                        </div>
                        <div>
                            <label style="display: block; font-size: 0.9rem; font-weight: 600; margin-bottom: 0.5rem; color: var(--text-dark);">Waktu (Misal: 10:00 WIB)</label>
                            <input type="text" name="time" required placeholder="10:00 WIB" style="width: 100%; padding: 0.8rem; border: 1px solid var(--border); border-radius: 8px;">
                        </div>
                        <div>
                            <label style="display: block; font-size: 0.9rem; font-weight: 600; margin-bottom: 0.5rem; color: var(--text-dark);">Warna Indikator</label>
                            <input type="color" name="color" value="#8B5A2B" style="width: 100%; height: 40px; border: 1px solid var(--border); border-radius: 8px; cursor: pointer;">
                        </div>
                        <button type="submit" class="btn-primary" style="margin-top: 0.5rem;">Simpan Kegiatan</button>
                    </form>
                </div>
            </div>

            <!-- Modal Pop-up Edit Jadwal -->
            <div id="editEventModal" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5); z-index: 1000; justify-content: center; align-items: center;">
                <div class="glass-card" style="background: white; padding: 2rem; border-radius: 12px; width: 90%; max-width: 400px; box-shadow: 0 10px 25px rgba(0,0,0,0.2);">
                    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem;">
                        <h3 style="color: var(--primary); margin: 0;">Edit Kegiatan</h3>
                        <button onclick="document.getElementById('editEventModal').style.display='none'" style="background: none; border: none; font-size: 1.2rem; cursor: pointer; color: var(--text-muted);">&times;</button>
                    </div>
                    <form id="editEventForm" action="/schedule/edit/" method="POST" style="display: flex; flex-direction: column; gap: 1rem;">
                        <div>
                            <label style="display: block; font-size: 0.9rem; font-weight: 600; margin-bottom: 0.5rem; color: var(--text-dark);">Nama Kegiatan</label>
                            <input type="text" id="editTitle" name="title" required style="width: 100%; padding: 0.8rem; border: 1px solid var(--border); border-radius: 8px;">
                        </div>
                        <div>
                            <label style="display: block; font-size: 0.9rem; font-weight: 600; margin-bottom: 0.5rem; color: var(--text-dark);">Tanggal</label>
                            <input type="date" id="editDate" name="date" required style="width: 100%; padding: 0.8rem; border: 1px solid var(--border); border-radius: 8px;">
                        </div>
                        <div>
                            <label style="display: block; font-size: 0.9rem; font-weight: 600; margin-bottom: 0.5rem; color: var(--text-dark);">Waktu</label>
                            <input type="text" id="editTime" name="time" required style="width: 100%; padding: 0.8rem; border: 1px solid var(--border); border-radius: 8px;">
                        </div>
                        <div>
                            <label style="display: block; font-size: 0.9rem; font-weight: 600; margin-bottom: 0.5rem; color: var(--text-dark);">Warna Indikator</label>
                            <input type="color" id="editColor" name="color" style="width: 100%; height: 40px; border: 1px solid var(--border); border-radius: 8px; cursor: pointer;">
                        </div>
                        <button type="submit" class="btn-primary" style="margin-top: 0.5rem;">Simpan Perubahan</button>
                    </form>
                </div>
            </div>
            <% } %>
        </div>
    </div>
</main>

<style>
    .calendar-grid {
        display: grid;
        grid-template-columns: repeat(7, 1fr);
        gap: 10px;
        text-align: center;
    }
    .weekday {
        font-weight: 600;
        color: var(--text-muted);
        font-size: 0.9rem;
        margin-bottom: 1rem;
    }
    .day-cell {
        width: 40px;
        height: 40px;
        margin: 0 auto;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 600;
        border-radius: 50%;
        cursor: pointer;
        transition: all 0.2s ease;
        position: relative;
    }
    .day-cell:hover {
        background-color: rgba(139, 90, 43, 0.1);
    }
    .day-cell.other-month {
        color: rgba(0,0,0,0.2);
    }
    .day-cell.has-event {
        color: white;
        box-shadow: 0 4px 10px rgba(0,0,0,0.15);
    }
    .day-cell.selected-day {
        outline: 3px solid var(--primary);
        outline-offset: 2px;
        transform: scale(1.1);
        z-index: 10;
    }
    
    .event-card {
        padding: 1.25rem;
        border-radius: 12px;
        color: white;
        box-shadow: 0 4px 15px rgba(0,0,0,0.05);
        transition: transform 0.2s;
    }
    .event-time {
        float: right;
        font-size: 0.85rem;
        opacity: 0.9;
        font-weight: bold;
        background: rgba(0,0,0,0.15);
        padding: 3px 8px;
        border-radius: 20px;
    }
    #prevMonth:hover, #nextMonth:hover {
        background-color: var(--primary) !important;
        color: white !important;
        transform: scale(1.05);
    }
    
    /* Scrollbar style for event list */
    #eventList::-webkit-scrollbar {
        width: 6px;
    }
    #eventList::-webkit-scrollbar-track {
        background: rgba(0,0,0,0.05); 
        border-radius: 10px;
    }
    #eventList::-webkit-scrollbar-thumb {
        background: var(--text-muted); 
        border-radius: 10px;
    }
</style>

<script>
    // Embedded JSON from backend safely
    const events = <%- JSON.stringify(schedule) %>;
    const isAdmin = <%- locals.user && (user.role === 'Admin' || user.role === 'Pengurus') ? 'true' : 'false' %>;
    
    const monthYearDisplay = document.getElementById('currentMonthYear');
    const calendarGrid = document.getElementById('calendarGrid');
    const eventListEl = document.getElementById('eventList');
    const eventListTitle = document.getElementById('eventListTitle');
    
    let currentDate = new Date(2026, 2, 1); 
    let selectedDate = null;

    const monthNames = ["Januari", "Februari", "Maret", "April", "Mei", "Juni", "Juli", "Agustus", "September", "Oktober", "November", "Desember"];

    function renderEventList(dateToFilter = null) {
        eventListEl.innerHTML = '';
        
        let filteredEvents;
        if (dateToFilter) {
            eventListTitle.textContent = `Kegiatan: ${dateToFilter.getDate()} ${monthNames[dateToFilter.getMonth()]} ${dateToFilter.getFullYear()}`;
            filteredEvents = events.filter(e => {
                const d = new Date(e.date);
                return d.getDate() === dateToFilter.getDate() && 
                       d.getMonth() === dateToFilter.getMonth() && 
                       d.getFullYear() === dateToFilter.getFullYear();
            });
        } else {
            eventListTitle.textContent = `Kegiatan Bulan Ini`;
            filteredEvents = events.filter(e => {
                const d = new Date(e.date);
                return d.getMonth() === currentDate.getMonth() && 
                       d.getFullYear() === currentDate.getFullYear();
            });
            filteredEvents.sort((a,b) => new Date(a.date) - new Date(b.date));
        }

        if (filteredEvents.length === 0) {
            eventListEl.innerHTML = `<p style="color:var(--text-muted); text-align:center; margin-top: 2rem;">Tidak ada kegiatan pada ${dateToFilter ? 'hari' : 'bulan'} ini.</p>`;
        } else {
            filteredEvents.forEach(e => {
                const eventDate = new Date(e.date);
                const dayName = ["Minggu", "Senin", "Selasa", "Rabu", "Kamis", "Jumat", "Sabtu"][eventDate.getDay()];
                const dList = document.createElement('div');
                dList.className = 'event-card';
                dList.style.backgroundColor = e.color || 'var(--accent)';
                
                let adminControls = '';
                if (isAdmin) {
                    adminControls = `
                        <div style="margin-top: 1rem; display: flex; gap: 10px; justify-content: flex-end; border-top: 1px solid rgba(255,255,255,0.2); padding-top: 0.8rem;">
                            <button onclick="openEditModal(${e.id})" style="background: rgba(255,255,255,0.2); color: white; border: none; padding: 6px 12px; border-radius: 6px; cursor: pointer; font-size: 0.8rem; transition: background 0.2s;" onmouseover="this.style.background='rgba(255,255,255,0.4)'" onmouseout="this.style.background='rgba(255,255,255,0.2)'"><i class="fa-solid fa-pen"></i> Edit</button>
                            <form action="/schedule/delete/${e.id}" method="POST" style="margin:0;" onsubmit="return confirm('Yakin ingin menghapus kegiatan ini?');">
                                <button type="submit" style="background: #dc2626; color: white; border: none; padding: 6px 12px; border-radius: 6px; cursor: pointer; font-size: 0.8rem; transition: opacity 0.2s;" onmouseover="this.style.opacity='0.8'" onmouseout="this.style.opacity='1'"><i class="fa-solid fa-trash"></i> Hapus</button>
                            </form>
                        </div>
                    `;
                }

                dList.innerHTML = `
                    <div class="event-time">${e.time}</div>
                    <div style="font-size: 0.9rem; margin-bottom: 0.5rem; opacity: 0.9;">${dayName}, ${eventDate.getDate()} ${monthNames[eventDate.getMonth()]}</div>
                    <div style="font-weight: 600; font-size: 1.1rem; line-height: 1.3;">${e.title}</div>
                    ${e.description ? `<div style="font-size: 0.85rem; opacity: 0.8; margin-top: 5px;">${e.description}</div>` : ''}
                    ${adminControls}
                `;
                eventListEl.appendChild(dList);
            });
        }
    }

    function openEditModal(eventId) {
        const event = events.find(e => e.id === eventId);
        if (event) {
            document.getElementById('editEventForm').action = '/schedule/edit/' + event.id;
            document.getElementById('editTitle').value = event.title;
            document.getElementById('editDate').value = event.date; // assuming ISO format YYYY-MM-DD from DB
            document.getElementById('editTime').value = event.time;
            document.getElementById('editColor').value = event.color || '#8B5A2B';
            document.getElementById('editEventModal').style.display = 'flex';
        }
    }

    function renderCalendar() {
        const year = currentDate.getFullYear();
        const month = currentDate.getMonth();
        
        monthYearDisplay.textContent = `${monthNames[month]} ${year}`;
        
        // Render events (default to month view if no specific day selected)
        if (!selectedDate || selectedDate.getMonth() !== month || selectedDate.getFullYear() !== year) {
            selectedDate = null; // Clear selection if we changed month
            renderEventList(null);
        } else {
            renderEventList(selectedDate);
        }

        const prevMonthDays = document.querySelectorAll('.day-cell');
        prevMonthDays.forEach(cell => cell.remove());

        const firstDayOfMonth = new Date(year, month, 1).getDay();
        const adjustedFirstDay = firstDayOfMonth === 0 ? 6 : firstDayOfMonth - 1;
        const daysInMonth = new Date(year, month + 1, 0).getDate();
        const daysInPrevMonth = new Date(year, month, 0).getDate();

        // Previous month padding
        for (let i = adjustedFirstDay - 1; i >= 0; i--) {
            const dayDiv = document.createElement('div');
            dayDiv.className = 'day-cell other-month';
            dayDiv.textContent = daysInPrevMonth - i;
            calendarGrid.appendChild(dayDiv);
        }

        // Current month cells
        for (let i = 1; i <= daysInMonth; i++) {
            const dayDiv = document.createElement('div');
            dayDiv.className = 'day-cell';
            dayDiv.textContent = i;
            
            // Check events
            const eventForDay = events.find(e => {
                const d = new Date(e.date);
                return d.getDate() === i && d.getMonth() === month && d.getFullYear() === year;
            });
            
            if (eventForDay) {
                dayDiv.classList.add('has-event');
                dayDiv.style.backgroundColor = eventForDay.color || 'var(--accent)';
            } else {
                dayDiv.style.backgroundColor = 'transparent';
                dayDiv.style.color = 'var(--text-dark)';
            }
            
            if (selectedDate && selectedDate.getDate() === i && selectedDate.getMonth() === month && selectedDate.getFullYear() === year) {
                dayDiv.classList.add('selected-day');
            }

            // Click listener
            dayDiv.addEventListener('click', () => {
                // Update selection
                selectedDate = new Date(year, month, i);
                
                // Remove selected class from all
                document.querySelectorAll('.day-cell').forEach(c => c.classList.remove('selected-day'));
                dayDiv.classList.add('selected-day');
                
                // Re-render event list for this day
                renderEventList(selectedDate);
            });

            calendarGrid.appendChild(dayDiv);
        }

        // Next month padding
        const totalCells = adjustedFirstDay + daysInMonth;
        const nextMonthPadding = 42 - totalCells; // Fill 6 weeks grid
        for(let i = 1; i <= nextMonthPadding; i++) {
            const dayDiv = document.createElement('div');
            dayDiv.className = 'day-cell other-month';
            dayDiv.textContent = i;
            calendarGrid.appendChild(dayDiv);
        }
    }

    document.getElementById('prevMonth').addEventListener('click', () => {
        currentDate.setMonth(currentDate.getMonth() - 1);
        renderCalendar();
    });

    document.getElementById('nextMonth').addEventListener('click', () => {
        currentDate.setMonth(currentDate.getMonth() + 1);
        renderCalendar();
    });

    // Initialize
    renderCalendar();
</script>
<%- include('layout/footer') %>
