<%- include('layout/header') %>
<main class="page-container" style="padding: 6rem 5%; max-width: 1200px; margin: 0 auto; min-height: 70vh;">
    <h1 class="section-title">Galeri Foto</h1>
    <div class="card-grid" style="grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 1.5rem;">
        <% if (photos && photos.length > 0) { %>
            <% photos.forEach(photo => { %>
                <div class="glass-card" style="padding: 1rem; text-align: center;">
                    <img src="<%= photo.url %>" alt="<%= photo.description %>" style="width: 100%; height: 250px; object-fit: cover; border-radius: 12px; margin-bottom: 1rem;">
                    <p style="font-weight: 600; color: var(--primary);"><%= photo.description %></p>
                </div>
            <% }) %>
        <% } else { %>
            <p style="grid-column: 1 / -1; text-align: center; color: var(--text-muted);">Belum ada foto dokumentasi.</p>
        <% } %>
    </div>
</main>
<%- include('layout/footer') %>
