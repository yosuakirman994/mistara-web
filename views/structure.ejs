<%- include('layout/header') %>
<main class="page-container" style="padding: 6rem 5%; max-width: 1200px; margin: 0 auto; min-height: 70vh;">
    <h1 class="section-title">Struktur Organisasi</h1>
    
    <style>
        .org-section {
            margin-bottom: 4rem;
            text-align: center;
        }
        .org-title {
            color: var(--primary);
            font-size: 1.5rem;
            margin-bottom: 0.5rem;
        }
        .org-line {
            width: 100%;
            height: 2px;
            background-color: var(--primary);
            margin: 0 auto 2rem auto;
        }
        .org-profile {
            display: inline-flex;
            flex-direction: column;
            align-items: center;
            margin: 1rem 0;
            padding: 0 1rem;
            text-align: center;
            min-width: 240px; /* Keep minimum width but allow expansion */
        }
        .org-photo-placeholder {
            width: 135px;
            height: 180px; /* Portrait aspect ratio 3:4 */
            border-radius: 8px; /* Slightly rounded corners, no longer a full circle */
            background-color: var(--bg-light);
            border: 2px dashed var(--accent);
            display: flex;
            align-items: center;
            justify-content: center;
            margin-bottom: 1rem;
            font-size: 0.9rem;
            overflow: hidden;
            position: relative;
        }
        .org-photo-placeholder span {
            color: var(--text-muted);
            position: absolute;
            z-index: 1;
        }
        .org-photo-placeholder img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            position: relative;
            z-index: 2;
        }
        .org-name {
            font-weight: 600;
            color: var(--text-dark);
            font-size: 1.1rem;
            margin-bottom: 0.3rem;
            /* text-wrap balance ensures long names look good on 2 lines */
            text-wrap: balance; 
        }
        .org-role {
            color: var(--text-muted);
            font-size: 0.9rem;
        }
        .org-row {
            display: flex;
            justify-content: center;
            flex-wrap: wrap;
            gap: 1rem;
            margin-top: 1rem;
        }
    </style>

